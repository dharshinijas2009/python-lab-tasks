#5.calendar
import calendar as cc
print("calendar of may\n",cc.month(2026,5))
print("calendar of the year:\n",cc.calendar(2026))
a=int(input("Enter the year:"))
print(f"{a}is leap year:{cc.isleap(a)}")
a=int(input("Enter the month:"))
print(cc.monthrange(2026,a)[1])
