#2.unit conversion
import scipy.constants as s
a=int(input("Enter the grams:"))
print(a,"gram=",a*s.gram,"Kilogram")
a=int(input("Enter the hour:"))
b=a*s.minute
print(f"{a}hours={b}minutes")
a=int(input("Enter the min:"))
b=a*s.minute
print(f"{a}minutes={b}seconds")
a=int(input("Enter the kilogram:"))
b=a*s.gram
print(f"{a}kilogram={b}grams")
a=int(input("Enter the  hour:"))
b=a*s.hour
print(f"{a}hours={b}seconds")

#3.time module
import time as t
print("current time:",t.strftime("%H:%M:%S"))
print("sleep the programm for 3 sec...")
t.sleep(3)
print("I'm awake")
print("Time in readable format",t.ctime())
print("Only hours:",t.strftime("%H"))
print("Only minutes:",t.strftime("%M"))
print("Only seconds:",t.strftime("%S"))

